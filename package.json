{
  "name": "tilezo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '@tilezo/client' build",
    "dev": "bun run --filter '@tilezo/server' --filter '@tilezo/client' --parallel dev",
    "dev:client": "bun run --filter '@tilezo/client' dev",
    "dev:server": "bun run --filter '@tilezo/server' dev",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "bun-types": "^1.3.13",
    "typescript": "^5.8.3"
  }
}
