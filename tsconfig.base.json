{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@tilezo/engine": ["./packages/engine/src/index.ts"],
      "@tilezo/engine/iso": ["./packages/engine/src/iso.ts"],
      "@tilezo/engine/types": ["./packages/engine/src/types.ts"],
      "@tilezo/protocol": ["./packages/protocol/src/index.ts"],
      "@tilezo/protocol/appearance": ["./packages/protocol/src/appearance.ts"],
      "@tilezo/protocol/economy": ["./packages/protocol/src/economy.ts"],
      "@tilezo/protocol/furniture": ["./packages/protocol/src/furniture.ts"],
      "@tilezo/protocol/messages": ["./packages/protocol/src/messages.ts"],
      "@tilezo/protocol/parse": ["./packages/protocol/src/parse.ts"],
      "@tilezo/protocol/user": ["./packages/protocol/src/user.ts"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": ["bun-types"]
  }
}
